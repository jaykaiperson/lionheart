    "accent_color":  "#FF9800",
    "notification_channel": "lionheart_vpn"
  },

  "icon": {
    "_comment": "Цвет фона иконки и цвет SVG-льва. Меняешь тут → build.sh подставит в XML.",
    "background_color": "#103bb0",
    "foreground_color": "#ffffff"
  },

  "supported_languages": ["en", "ru", "be", "tt"],
  "default_language": "en"
}